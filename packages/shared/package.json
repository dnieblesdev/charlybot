{
  "name": "@charlybot/shared",
  "version": "3.0.1",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./prisma": "./src/generated/prisma/index.js",
    "./schemas/*": "./src/schemas/*.ts"
  },
  "scripts": {
    "db:generate": "pnpm exec prisma generate --schema=./prisma/schema.prisma",
    "db:push": "pnpm exec prisma db push --schema=./prisma/schema.prisma"
  },
  "dependencies": {
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/sdk-node": "0.55.0",
    "@prisma/instrumentation": "6.19.3",
    "pg": "8.20.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "ioredis": "5.10.1",
    "prom-client": "15.1.3",
    "winston": "3.19.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "prisma": "7.8.0",
    "sql.js": "1.14.1"
  }
}
