{
  "name": "@charlybot/shared",
  "version": "2.3.1",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./prisma": "./src/generated/prisma/index.js",
    "./schemas/*": "./src/schemas/*.ts"
  },
  "scripts": {
    "db:generate": "bunx prisma generate --schema=./prisma/schema.prisma",
    "db:push": "bunx prisma db push --schema=./prisma/schema.prisma"
  },
  "dependencies": {
    "@libsql/client": "latest",
    "@prisma/adapter-libsql": "latest",
    "@prisma/client": "^7.6.0",
    "zod": "latest"
  },
  "devDependencies": {
    "prisma": "latest"
  }
}
