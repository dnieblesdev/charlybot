{
  "name": "@charlybot/shared",
  "version": "2.5.3",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./prisma": "./src/generated/prisma/index.js",
    "./schemas/*": "./src/schemas/*.ts"
  },
  "scripts": {
    "db:generate": "bunx prisma generate --schema=./prisma/schema.prisma",
    "db:push": "bunx prisma db push --schema=./prisma/schema.prisma"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.55.0",
    "@prisma/instrumentation": "^6.4.0",
    "@libsql/client": "latest",
    "@prisma/adapter-libsql": "latest",
    "@prisma/client": "^7.6.0",
    "ioredis": "^5.4.2",
    "prom-client": "^15.1.3",
    "winston": "^3.18.0",
    "zod": "latest"
  },
  "devDependencies": {
    "prisma": "latest"
  }
}
