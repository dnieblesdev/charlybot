{
  "name": "@charlybot/shared",
  "version": "3.0.0",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./prisma": "./src/generated/prisma/index.js",
    "./schemas/*": "./src/schemas/*.ts"
  },
  "scripts": {
    "db:generate": "pnpm exec prisma generate --schema=./prisma/schema.prisma",
    "db:push": "pnpm exec prisma db push --schema=./prisma/schema.prisma"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.55.0",
    "@prisma/instrumentation": "^6.4.0",
    "pg": "^8.13.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "ioredis": "^5.4.2",
    "prom-client": "^15.1.3",
    "winston": "^3.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "prisma": "^7.6.0",
    "sql.js": "^1.12.0"
  }
}
