# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_bot_client_id_here

# Optional: Specify a guild ID for faster command registration during development
# Leave empty for global commands (slower but works in all servers)
GUILD_ID=your_server_guild_id_here

# Optional: Spotify Integration (for music commands)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Bot Configuration
# Set to 'development' or 'production'
NODE_ENV=development

# Log Level (error, warn, info, debug)
LOG_LEVEL=info

# Valkey (Redis-compatible) Configuration
VALKEY_HOST=localhost
VALKEY_PORT=6379
VALKEY_PASSWORD=your_valkey_password_here
VALKEY_CONNECT_TIMEOUT_MS=5000
VALKEY_COMMAND_TIMEOUT_MS=2000
VALKEY_MAX_RETRIES=3
VALKEY_PREFIX=cb
VALKEY_ENV=development
