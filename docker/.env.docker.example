# Variables para desarrollo Docker
# Copiá este archivo como .env.docker y completá con tus valores

# Discord Bot
DISCORD_TOKEN=tu_token_aqui
CLIENT_ID=tu_client_id_aqui
GUILD_ID=tu_guild_id_aqui

# Discord OAuth2 (para dashboard web)
DISCORD_CLIENT_ID=tu_client_id_aqui
DISCORD_CLIENT_SECRET=tu_client_secret_aqui
DISCORD_REDIRECT_URI=http://localhost/api/v1/auth/callback

# Database
DATABASE_URL=file:./dev.db

# API
API_URL=http://api:3000
API_KEY=charly_secret_key

# Puerto API
API_PORT=3000

# JWT (para autenticación del dashboard)
JWT_SECRET=cambia_esto_por_un_string_largo_y_randomo_min_32_chars

# Valkey
VALKEY_PREFIX=cb
