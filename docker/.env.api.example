# API environment variables for production Docker
# Copy to .env.api and fill in real values

# API authentication key (required)
API_KEY=

# Server port
PORT=3000

# Logging
LOG_LEVEL=info

# Database connection
DATABASE_URL=postgresql://charlybot:changeme@postgres:5432/charlybot

# Valkey connection
VALKEY_HOST=valkey
VALKEY_PORT=6379
VALKEY_PASSWORD=
VALKEY_PREFIX=charlybot:
VALKEY_MAX_RETRIES=3

# OpenTelemetry (optional)
OTEL_ENABLED=false