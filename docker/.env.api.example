# API Server — Development Environment Variables
# Copy to .env.api and fill in real values
# Use: docker compose -f docker/docker-compose.dev.yml up

# API Server
API_KEY=charly_secret_key
PORT=3000
LOG_LEVEL=info
DATABASE_URL=file:/app/packages/shared/dev.db

# Valkey
VALKEY_HOST=valkey
VALKEY_PORT=6379
VALKEY_PREFIX=cb

# Discord OAuth2
DISCORD_CLIENT_ID=discord_client_id
DISCORD_CLIENT_SECRET=your_discord_oauth2_secret_here
DISCORD_REDIRECT_URI=http://localhost/api/v1/auth/callback

# JWT (must be a real random string, min 32 chars — generate with: openssl rand -base64 32)
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars
