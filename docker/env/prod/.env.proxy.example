# Nginx reverse proxy — Production Environment Variables
# Copy to .env.proxy and configure for your environment
# Use: docker compose -f docker/docker-compose.yml up

# HTTPS configuration
NGINX_HTTPS_ENABLED=true

# SSL certificate paths (mounted via volumes in docker-compose)
# SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
# SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# Optional: redirect HTTP to HTTPS
# NGINX_HTTP_TO_HTTPS_REDIRECT=true

# Optional: HSTS header
# NGINX_HSTS_ENABLED=true
# NGINX_HSTS_MAX_AGE=31536000