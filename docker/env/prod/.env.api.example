# API environment variables for production Docker
# Copy to .env.api and fill in real values

# API authentication key (required)
API_KEY=your_production_api_key

# Server port
PORT=3000

# Logging
LOG_LEVEL=info

# Database connection (external/managed production PostgreSQL).
# Production compose does not run PostgreSQL; point this to your DB host.
DATABASE_URL=postgresql://charlybot:your_secure_password@your-postgres-host:5432/charlybot

# Valkey connection
VALKEY_HOST=valkey
VALKEY_PORT=6379
VALKEY_PASSWORD=your_valkey_password
VALKEY_PREFIX=charlybot:
VALKEY_MAX_RETRIES=3

# Discord OAuth2 (production)
DISCORD_CLIENT_ID=your_production_discord_client_id
DISCORD_CLIENT_SECRET=your_production_discord_client_secret
DISCORD_REDIRECT_URI=https://yourdomain.com/api/v1/auth/callback

# JWT (min 32 chars random string - use a strong random generator)
JWT_SECRET=your_production_jwt_secret_min_32_chars_random

# OpenTelemetry (optional)
OTEL_ENABLED=false
