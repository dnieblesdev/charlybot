# Bot environment variables for production Docker
# Copy to .env.bot and fill in real values

# Discord bot token (required)
DISCORD_TOKEN=your_production_discord_bot_token

# Application command registration
CLIENT_ID=your_production_client_id
GUILD_ID=your_production_guild_id
GUILD_ID2=your_second_guild_id
GUILD_ID3=your_third_guild_id
OWNER_ID=your_owner_id

# Bot API endpoint (internal)
API_URL=http://api:3000
API_KEY=your_production_api_key

# Valkey connection
VALKEY_HOST=valkey
VALKEY_PORT=6379
VALKEY_PASSWORD=your_valkey_password
VALKEY_PREFIX=charlybot:
VALKEY_MAX_RETRIES=3

# Logging
LOG_LEVEL=info

# Spotify credentials (optional - for music)
SPOTIFY_CLIENT_ID=your_production_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_production_spotify_client_secret
SPOTIFY_REFRESH_TOKEN=your_production_spotify_refresh_token

# Database (external/managed production PostgreSQL).
# Production compose does not run PostgreSQL; point this to your DB host.
DATABASE_URL=postgresql://charlybot:your_secure_password@your-postgres-host:5432/charlybot
