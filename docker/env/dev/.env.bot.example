# Discord Bot — Development Environment Variables
# Copy to .env.bot and fill in real values
# Use: docker compose -f docker/docker-compose.dev.yml up

# Discord Bot
DISCORD_TOKEN=your_discord_bot_token
CLIENT_ID=your_client_id
GUILD_ID=your_guild_id
GUILD_ID2=your_second_guild_id
GUILD_ID3=your_third_guild_id
OWNER_ID=your_owner_id

# API
API_URL=http://api:3000
API_KEY=your_api_key

# Spotify (optional - for music features)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REFRESH_TOKEN=your_spotify_refresh_token

# Database
DATABASE_URL=postgresql://charlybot:password@host.docker.internal:5432/db_charlybot

# Valkey
VALKEY_HOST=valkey
VALKEY_PORT=6379
VALKEY_PREFIX=cb