# API Server — Development Environment Variables
# Copy to .env.api and fill in real values
# Use: docker compose -f docker/docker-compose.dev.yml up

# API Server
API_KEY=your_api_key_here
PORT=3000
LOG_LEVEL=info

# Database connection.
# Default: local PostgreSQL running on the host machine.
# Optional Docker DB profile: change host.docker.internal to postgres and run
# docker compose -f docker/docker-compose.dev.yml --profile db up
DATABASE_URL=postgresql://charlybot:password@host.docker.internal:5432/charlybot

# Valkey
# Docker Compose also loads .env.valkey so API uses the same VALKEY_PASSWORD
# as the Valkey service when dev auth is enabled.
VALKEY_HOST=valkey
VALKEY_PORT=6379
VALKEY_PREFIX=cb

# Discord OAuth2
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://127.0.0.1/api/v1/auth/callback

# JWT (min 32 chars random string)
JWT_SECRET=your_jwt_secret_min_32_chars
